---
import Icon from './Icon.astro';
import { stack } from '../data/stack';
import { dict } from '../i18n/content';

const t = dict.stack;
const total = stack.reduce((sum, layer) => sum + layer.techs.length, 0);
---

<section class="sec" id="stack">
  <div class="sec-head reveal">
    <div class="eyebrow" data-i18n="stack.eyebrow">{t.eyebrow}</div>
    <h2 data-i18n="stack.title">{t.title}</h2>
    <p class="sub">
      <span data-i18n="stack.sub">{t.sub}</span>
      <span class="stack-count"
        >// {total}
        <span data-i18n="stack.technologies">{t.technologies}</span> · {
          stack.length
        }
        <span data-i18n="stack.layers">{t.layers}</span></span
      >
    </p>
  </div>
  <div class="layers">
    {
      stack.map((layer, li) => (
        <div class="layer reveal" data-d={(li * 0.07).toFixed(2)}>
          <div class="layer-rail">
            <div class="layer-node">
              <span class="lm">{layer.mark}</span>
              <span class="lx">{layer.idx}</span>
            </div>
          </div>
          <div class="layer-body">
            <div class="layer-head">
              <h3 data-i18n={`stack.items.${li}.name`}>{t.items[li].name}</h3>
              <span class="cnt">
                {layer.techs.length}{' '}
                <span data-i18n="stack.modules">{t.modules}</span>
              </span>
              <span class="lnote" data-i18n={`stack.items.${li}.note`}>
                {t.items[li].note}
              </span>
            </div>
            <div class="techs">
              {layer.techs.map((tech, ti) => (
                <span
                  class="tech"
                  data-note={t.items[li].techs[ti]}
                  data-i18n-attr={`data-note:stack.items.${li}.techs.${ti}`}
                >
                  <span class="ti" style={`color:${tech.color}`}>
                    {tech.icon ? (
                      <Icon name={tech.icon} size={17} />
                    ) : (
                      <b class="tm">{tech.mono}</b>
                    )}
                  </span>
                  <span class="tn">{tech.label}</span>
                </span>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
