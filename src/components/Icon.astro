---
/**
 * Build-time SVG icon (monochrome, `currentColor`).
 *
 * Inlines ONLY the referenced icon into the HTML at build time from the
 * `@iconify-json/devicon-plain` devDependency; the full set is never shipped,
 * there is no runtime JS and no icon-font CDN. Color it via CSS `color` on a
 * parent (the SVG uses `currentColor`).
 *
 * Usage:  <Icon name="react" size={17} />   (browse: https://icon-sets.iconify.design/devicon-plain/)
 */
import { icons } from '@iconify-json/devicon-plain';
import { getIconData, iconToSVG, iconToHTML, replaceIDs } from '@iconify/utils';

/** Icons absent from devicon-plain, supplied inline (monochrome, currentColor). */
const OVERRIDES: Record<string, { viewBox: string; body: string }> = {
  react: {
    viewBox: '0 0 24 24',
    body: '<circle cx="12" cy="12" r="2.05" fill="currentColor"/><g fill="none" stroke="currentColor" stroke-width="1"><ellipse cx="12" cy="12" rx="11" ry="4.2"/><ellipse cx="12" cy="12" rx="11" ry="4.2" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="11" ry="4.2" transform="rotate(120 12 12)"/></g>',
  },
};

interface Props {
  name: string;
  size?: number;
  title?: string;
  class?: string;
}

const { name, size = 24, title, class: className } = Astro.props;

let body: string;
let attributes: Record<string, string>;

const override = OVERRIDES[name];
if (override) {
  body = override.body;
  attributes = { width: String(size), height: String(size), viewBox: override.viewBox };
} else {
  const data = getIconData(icons, name);
  if (!data) {
    throw new Error(
      `[Icon] Unknown icon "${name}" in devicon-plain. Browse: https://icon-sets.iconify.design/devicon-plain/`,
    );
  }
  const built = iconToSVG(data, { height: size });
  body = built.body;
  attributes = built.attributes as unknown as Record<string, string>;
}

const svg = iconToHTML(replaceIDs(body), {
  xmlns: 'http://www.w3.org/2000/svg',
  ...attributes,
  ...(className ? { class: className } : {}),
  ...(title ? { role: 'img', 'aria-label': title } : { 'aria-hidden': 'true' }),
});
---

<Fragment set:html={svg} />
