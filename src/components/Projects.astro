---
import { Picture } from 'astro:assets';
import { projectGroups } from '../data/projects';
import { dict } from '../i18n/content';

const t = dict.proj;
---

<section class="sec" id="projects">
  <div class="sec-head reveal">
    <div class="eyebrow" data-i18n="proj.eyebrow">{t.eyebrow}</div>
    <h2 data-i18n="proj.title">{t.title}</h2>
    <p class="sub" data-i18n="proj.sub">{t.sub}</p>
  </div>
  <div class="proj-groups">
    {
      projectGroups.map((group, gi) => {
        const g = t.groups[gi];
        const count = String(group.items.length).padStart(2, '0');
        return (
          <div class="proj-group-section">
            <div class="proj-group reveal">
              <span class="pg-label">
                {group.kind === 'team' ? (
                  <svg
                    class="pg-ico"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <circle cx="9" cy="8.5" r="3" />
                    <path d="M3.4 19a5.6 5.6 0 0 1 11.2 0" />
                    <path d="M15.5 6.3a3 3 0 0 1 0 5.4M17.8 19a5.6 5.6 0 0 0-2.3-4.5" />
                  </svg>
                ) : (
                  <svg
                    class="pg-ico"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="8" r="3.4" />
                    <path d="M5.6 20a6.4 6.4 0 0 1 12.8 0" />
                  </svg>
                )}
                <span data-i18n={`proj.groups.${gi}.label`}>{g.label}</span>
              </span>
              <span class="pg-rule" />
              <span class="pg-meta">
                <span data-i18n={`proj.groups.${gi}.note`}>{g.note}</span> ·{' '}
                {count}
              </span>
            </div>
            <div class="proj-grid">
              {group.items.map((p, i) => {
                const item = g.items[i];
                const live = item.live;
                const base = `proj.groups.${gi}.items.${i}`;
                return (
                  <article class="proj reveal">
                    <div class:list={['proj-thumb', !p.image && 'pt-abstract']}>
                      {p.image ? (
                        <Fragment>
                          <Picture
                            src={p.image}
                            alt={item.alt ?? ''}
                            data-i18n-attr={`alt:${base}.alt`}
                            formats={['avif', 'webp']}
                            fallbackFormat="webp"
                            widths={[480, 760, 1100, 1600]}
                            sizes="(max-width:820px) 92vw, 54vw"
                          />
                          <span class="zoom-hint">
                            <span class="zh">
                              <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.8"
                              >
                                <circle cx="11" cy="11" r="7" />
                                <path d="M21 21l-4.3-4.3M11 8.5v5M8.5 11h5" />
                              </svg>
                            </span>
                          </span>
                        </Fragment>
                      ) : (
                        <Fragment>
                          <div class="pa-grid" />
                          <span class="pa-glyph">{p.glyph}</span>
                          {p.tag && <span class="pa-tag">{p.tag}</span>}
                        </Fragment>
                      )}
                    </div>
                    <div class="proj-body">
                      <div class="p-top">
                        <span class="p-year" data-i18n={`${base}.year`}>
                          {item.year}
                        </span>
                      </div>
                      <h3 data-i18n={`${base}.title`}>{item.title}</h3>
                      {live && (
                        <span class="live">
                          <i />
                          <span data-i18n={`${base}.live`}>{live}</span>
                        </span>
                      )}
                      <p class="p-product" data-i18n={`${base}.product`}>
                        {item.product}
                      </p>
                      <details class="p-tech">
                        <summary data-i18n="proj.techDetails">
                          {t.techDetails}
                        </summary>
                        <div class="chips">
                          {p.tags.map((tag) => (
                            <span class={tag.hot ? 'hot' : undefined}>
                              {tag.label}
                            </span>
                          ))}
                        </div>
                        <p class="p-tech-body" data-i18n={`${base}.tech`}>
                          {item.tech}
                        </p>
                      </details>
                      {(p.link || p.repo) && (
                        <div class="p-links">
                          {p.link && (
                            <a
                              class="view"
                              href={p.link}
                              target="_blank"
                              rel="noopener"
                            >
                              <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.8"
                              >
                                <path d="M7 17 17 7M9 7h8v8" />
                              </svg>
                              <span data-i18n="proj.view">{t.view}</span>
                            </a>
                          )}
                          {p.repo === 'walkthrough' && (
                            <a class="ask" href="#contact">
                              <svg
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                aria-hidden="true"
                              >
                                <path d="M12 2A10 10 0 0 0 8.8 21.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .8.1-.6.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5 .3.3.6.9.6 1.9v2.8c0 .3.2.6.7.5A10 10 0 0 0 12 2Z" />
                              </svg>
                              <span data-i18n="proj.walkthrough">
                                {t.walkthrough}
                              </span>
                            </a>
                          )}
                          {p.repo === 'private' && (
                            <span class="priv">
                              <svg
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                aria-hidden="true"
                              >
                                <path d="M12 2A10 10 0 0 0 8.8 21.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .8.1-.6.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5 .3.3.6.9.6 1.9v2.8c0 .3.2.6.7.5A10 10 0 0 0 12 2Z" />
                              </svg>
                              <span data-i18n="proj.privateRepo">
                                {t.privateRepo}
                              </span>
                            </span>
                          )}
                        </div>
                      )}
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        );
      })
    }
  </div>
</section>
