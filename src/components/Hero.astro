---
import { Picture } from 'astro:assets';
import profile from '../assets/profile.png';
import Icon from './Icon.astro';
import { site } from '../data/site';
import { coreStack } from '../data/coreStack';
---

<section class="sec intro" id="about">
  <div class="intro-top load-fx" style="transition-delay:.12s">
    <div class="avatar">
      <Picture
        src={profile}
        alt={`${site.name} — ${site.role}`}
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        widths={[116, 232]}
        sizes="116px"
      />
    </div>
    <div class="intro-id">
      <div class="kicker">{site.kicker}</div>
      <h1 class="name-reveal">{site.firstName} <span class="l2">{site.lastName}</span></h1>
      <div class="title">
        {site.role} <span class="tagline"><span class="tw" id="tw"></span></span>
      </div>
      <span class="loc"><i></i>{site.location}</span>
    </div>
  </div>

  <p class="about-lead load-fx" style="transition-delay:.26s">
    Full-Stack Engineer with <b>6+ years</b> designing, building and operating
    <b>production-grade TypeScript</b> applications — React &amp; Next.js frontends, NestJS APIs,
    PostgreSQL and cloud infrastructure on AWS &amp; Linux VPS with Docker, Traefik and CI/CD. I ship
    scalable multi-tenant systems and business-critical integrations with Stripe, Shopee, Google Maps
    and AI-powered OCR.
  </p>

  <div class="core load-fx" style="transition-delay:.38s">
    <div class="core-l">Core stack</div>
    <div class="core-chips">
      {
        coreStack.map((c) => (
          <span class="cchip">
            {c.icon ? <Icon name={c.icon} size={15} /> : <b class="cm">{c.mono}</b>}
            <span>{c.label}</span>
          </span>
        ))
      }
    </div>
  </div>

  <div class="intro-actions load-fx" style="transition-delay:.5s">
    <a class="cline" href={`mailto:${site.email}`} aria-label="Email">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"
        ><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg
      >
      {site.email}
    </a>
    <a class="cline" href={site.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp">
      <svg viewBox="0 0 24 24" fill="currentColor"
        ><path
          d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.4A10 10 0 1 0 12 2Zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20Zm4.4-5.8c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-1.9-1.2 7.3 7.3 0 0 1-1.3-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4a.4.4 0 0 0 0-.4l-.8-1.8c-.2-.5-.4-.4-.5-.4h-.5a.9.9 0 0 0-.7.3 2.8 2.8 0 0 0-.9 2.1 4.9 4.9 0 0 0 1 2.6 11 11 0 0 0 4.3 3.8c1.5.6 1.8.5 2.2.5a2.5 2.5 0 0 0 1.6-1.2 2 2 0 0 0 .2-1.2c-.1-.1-.3-.2-.5-.3Z"
        ></path></svg
      >
      {site.phone}
    </a>
    <a class="btn" href={site.linkedin} target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor"
        ><path
          d="M4.98 3.5A2.5 2.5 0 1 1 0 3.5a2.5 2.5 0 0 1 4.98 0ZM.2 8.2h4.6V24H.2V8.2Zm7.4 0h4.4v2.2h.1c.6-1.1 2.1-2.3 4.3-2.3 4.6 0 5.5 3 5.5 7V24h-4.6v-6.9c0-1.6 0-3.7-2.3-3.7s-2.6 1.8-2.6 3.6V24H7.6V8.2Z"
        ></path></svg
      >
      LinkedIn
    </a>
    <a class="btn ph" href="#" data-ph="GitHub URL — pending">
      <svg viewBox="0 0 24 24" fill="currentColor"
        ><path
          d="M12 2A10 10 0 0 0 8.8 21.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .8.1-.6.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5 .3.3.6.9.6 1.9v2.8c0 .3.2.6.7.5A10 10 0 0 0 12 2Z"
        ></path></svg
      >
      GitHub
    </a>
    <a class="btn solid ph" href="#" data-ph="CV PDF — coming soon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
        ><path d="M12 3v12m0 0 4-4m-4 4-4-4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"></path></svg
      >
      Download CV
    </a>
  </div>
</section>
