---
import { site } from '../data/site';
import { dict } from '../i18n/content';

const t = dict.colophon;
---

<aside class="colophon">
  <div class="wrap colo-row reveal">
    <div class="colo-main">
      <div class="colo-label" data-i18n="colophon.label">{t.label}</div>
      <p class="colo-text" data-i18n-html="colophon.text" set:html={t.text} />
    </div>
    <div class="colo-side">
      <div class="colo-metrics">
        <span class="colo-chip">0 runtime deps</span>
        <span class="colo-chip">~3 KB JS</span>
        <span class="colo-chip">Lighthouse 99+</span>
      </div>
      <a class="colo-src" href={site.repo} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
          ><path
            d="M12 2A10 10 0 0 0 8.8 21.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .8.1-.6.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5 .3.3.6.9.6 1.9v2.8c0 .3.2.6.7.5A10 10 0 0 0 12 2Z"
          ></path></svg
        >
        <span data-i18n="colophon.source">{t.source}</span> ↗
      </a>
    </div>
  </div>
</aside>
