---
import { site } from '../data/site';
import { dict } from '../i18n/content';

const t = dict.contact;
---

<section class="sec contact-sec" id="contact">
  <div class="sec-head reveal">
    <div class="eyebrow" data-i18n="contact.eyebrow">{t.eyebrow}</div>
    <h2 data-i18n="contact.title">{t.title}</h2>
    <p class="sub" data-i18n="contact.sub">{t.sub}</p>
  </div>
  <div class="contact-wrap">
    <form class="cform reveal" id="cform" novalidate>
      <div class="field">
        <label for="cf-name" data-i18n="contact.name">{t.name}</label>
        <input
          id="cf-name"
          name="name"
          type="text"
          required
          maxlength="100"
          autocomplete="name"
          aria-describedby="cf-name-err"
          placeholder={t.namePh}
          data-i18n-attr="placeholder:contact.namePh"
        />
        <span class="field-err" id="cf-name-err" role="alert"></span>
      </div>
      <div class="field">
        <label for="cf-email" data-i18n="contact.email">{t.email}</label>
        <input
          id="cf-email"
          name="email"
          type="email"
          required
          maxlength="255"
          autocomplete="email"
          aria-describedby="cf-email-err"
          placeholder={t.emailPh}
          data-i18n-attr="placeholder:contact.emailPh"
        />
        <span class="field-err" id="cf-email-err" role="alert"></span>
      </div>
      <div class="field">
        <label for="cf-msg" data-i18n="contact.message">{t.message}</label>
        <textarea
          id="cf-msg"
          name="message"
          rows="5"
          required
          maxlength="3000"
          aria-describedby="cf-msg-err"
          placeholder={t.msgPh}
          data-i18n-attr="placeholder:contact.msgPh"></textarea>
        <span class="field-err" id="cf-msg-err" role="alert"></span>
      </div>
      {/* Honeypot: hidden from people, tempting to bots. */}
      <div class="hp" aria-hidden="true">
        <label for="cf-website">Website</label>
        <input
          id="cf-website"
          name="website"
          type="text"
          tabindex="-1"
          autocomplete="off"
        />
      </div>
      <div class="cform-foot">
        <button class="cform-send" type="submit">
          <span data-i18n="contact.send">{t.send}</span>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            ><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7Z"></path></svg
          >
        </button>
        <span class="cform-note" id="cformNote" data-i18n="contact.note"
          >{t.note}</span
        >
      </div>
      <p
        class="cform-status"
        id="cformStatus"
        role="status"
        aria-live="polite"
      ></p>
    </form>
    <div class="contact-side reveal" data-d=".1">
      <a class="ccard" href={`mailto:${site.email}`}>
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          ><rect x="3" y="5" width="18" height="14" rx="2"></rect><path
            d="m3 7 9 6 9-6"></path></svg
        >
        <div class="cl">Email</div>
        <div class="cv">{site.email}</div>
      </a>
      <a class="ccard" href={site.whatsapp} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.4A10 10 0 1 0 12 2Zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20Zm4.4-5.8c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-1.9-1.2 7.3 7.3 0 0 1-1.3-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4a.4.4 0 0 0 0-.4l-.8-1.8c-.2-.5-.4-.4-.5-.4h-.5a.9.9 0 0 0-.7.3 2.8 2.8 0 0 0-.9 2.1 4.9 4.9 0 0 0 1 2.6 11 11 0 0 0 4.3 3.8c1.5.6 1.8.5 2.2.5a2.5 2.5 0 0 0 1.6-1.2 2 2 0 0 0 .2-1.2c-.1-.1-.3-.2-.5-.3Z"
          ></path></svg
        >
        <div class="cl">WhatsApp</div>
        <div class="cv">{site.phone}</div>
      </a>
      <a class="ccard" href={site.linkedin} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M4.98 3.5A2.5 2.5 0 1 1 0 3.5a2.5 2.5 0 0 1 4.98 0ZM.2 8.2h4.6V24H.2V8.2Zm7.4 0h4.4v2.2h.1c.6-1.1 2.1-2.3 4.3-2.3 4.6 0 5.5 3 5.5 7V24h-4.6v-6.9c0-1.6 0-3.7-2.3-3.7s-2.6 1.8-2.6 3.6V24H7.6V8.2Z"
          ></path></svg
        >
        <div class="cl">LinkedIn</div>
        <div class="cv">{site.linkedinHandle}</div>
      </a>
      <a class="ccard" href={site.github} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 2A10 10 0 0 0 8.8 21.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .8.1-.6.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5 .3.3.6.9.6 1.9v2.8c0 .3.2.6.7.5A10 10 0 0 0 12 2Z"
          ></path></svg
        >
        <div class="cl">GitHub</div>
        <div class="cv">@TercerosDante</div>
      </a>
    </div>
  </div>
</section>
