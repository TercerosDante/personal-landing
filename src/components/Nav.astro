---
import { site } from '../data/site';
import { nav } from '../data/nav';
import { dict } from '../i18n/content';
---

<header class="topbar">
  <div class="brand" data-go="#about">
    <b>RONALD&nbsp;TERCEROS</b>
  </div>
  <nav class="nav" id="nav">
    {
      nav.map((item, i) => (
        <a href={item.href} class={i === 0 ? 'on' : undefined}>
          <span class="mnum" aria-hidden="true">
            {String(i).padStart(2, '0')}
          </span>
          <span class="mlabel" data-i18n={`nav.${item.key}`}>
            {dict.nav[item.key]}
          </span>
        </a>
      ))
    }
    <a
      href={site.cv.en}
      class="cvbtn"
      data-cv-dl
      download="Ronald-Terceros-CV-EN.pdf"
      data-i18n="nav.cv">{dict.nav.cv}</a
    >
  </nav>
  <div class="navtools">
    <button
      id="langToggle"
      class="lang-toggle"
      type="button"
      aria-label="Cambiar a español"
    >
      <svg
        class="globe"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        aria-hidden="true"
        ><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18"></path><path
          d="M12 3c2.7 2.4 4 5.6 4 9s-1.3 6.6-4 9c-2.7-2.4-4-5.6-4-9s1.3-6.6 4-9Z"
        ></path></svg
      >
      <span class="lang-code">ES</span>
    </button>
    <button
      class="menu-btn"
      id="menuBtn"
      type="button"
      aria-label="Open menu"
      aria-controls="nav"
      aria-expanded="false"><i></i><i></i><i></i></button
    >
  </div>
</header>
