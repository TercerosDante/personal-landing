---
import { education, languages } from '../data/education';
---

<section class="sec" id="education">
  <div class="sec-head reveal">
    <div class="eyebrow">04 / Education</div>
    <h2>Training &amp; languages.</h2>
  </div>
  <div class="edu-grid">
    <div class="edu-list">
      {
        education.map((e, i) => (
          <div class="edu reveal" data-d={i ? (i * 0.06).toFixed(2) : undefined}>
            <div class="yr">{e.year}</div>
            <div class="ed-b">
              <h4>{e.title}</h4>
              <div class="inst">{e.inst}</div>
            </div>
          </div>
        ))
      }
    </div>
    <div class="lang-card reveal" data-d=".1">
      <div class="lc-h">Languages</div>
      {
        languages.map((l) => (
          <div class="lang">
            <div class="lt">
              {l.name} <span>{l.level}</span>
            </div>
            <div class="bar">
              <i style={`width:${l.pct}%`} />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
