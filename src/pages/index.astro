---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="shell">
    <p class="eyebrow">Full-Stack Engineer · Bolivia · Remote</p>
    <h1>Ronald Terceros</h1>
    <p class="note">
      New site in progress — the portfolio is being rebuilt in Astro.
    </p>
  </main>
</Layout>

<style is:global>
  html,
  body {
    margin: 0;
    min-height: 100%;
  }
  body {
    background: #f3f1ec;
    color: #222a36;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      "Segoe UI",
      sans-serif;
    -webkit-font-smoothing: antialiased;
  }
</style>

<style>
  .shell {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
    max-width: 42rem;
    margin: 0 auto;
    padding: 2rem;
  }
  .eyebrow {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #d8623f;
  }
  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 9vw, 4.75rem);
    letter-spacing: -0.035em;
    line-height: 1;
  }
  .note {
    margin: 0.25rem 0 0;
    max-width: 34ch;
    line-height: 1.6;
    color: #4a5160;
  }
</style>
