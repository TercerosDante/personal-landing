---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { site } from '../data/site';
import { content } from '../i18n/content';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} · ${site.role}`,
  description = site.description,
} = Astro.props;

// Spanish copy + the EN-only bits the client needs (typewriter words, contact
// form states), embedded once for the in-place language toggle (src/scripts/i18n.ts).
const i18nData = {
  es: content.es,
  enExtra: {
    tagline: content.en.hero.tagline,
    form: {
      sending: content.en.contact.sending,
      success: content.en.contact.success,
      errorGeneric: content.en.contact.errorGeneric,
      errorNetwork: content.en.contact.errorNetwork,
      errorVerification: content.en.contact.errorVerification,
      errorTooLong: content.en.contact.errorTooLong,
      errorInvalid: content.en.contact.errorInvalid,
      invalidName: content.en.contact.invalidName,
      invalidEmail: content.en.contact.invalidEmail,
      invalidMessage: content.en.contact.invalidMessage,
    },
  },
};

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.role,
  description: site.description,
  url: Astro.site?.href,
  image: ogImage,
  email: `mailto:${site.email}`,
  address: { '@type': 'PostalAddress', addressCountry: 'BO' },
  knowsAbout: [
    'TypeScript',
    'React',
    'Next.js',
    'Node.js',
    'NestJS',
    'PostgreSQL',
    'Prisma',
    'GraphQL',
    'AWS',
    'Docker',
    'Kubernetes',
  ],
  sameAs: [site.linkedin, site.github].filter(Boolean),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph (LinkedIn, WhatsApp, Slack, Facebook…) */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} · ${site.role}`} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="es_ES" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Structured data (schema.org/Person) */}
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(personLd)}
    />

    <Font cssVariable="--font-archivo" />
    <Font cssVariable="--font-mono" />
  </head>
  <body>
    <script
      type="application/json"
      id="i18n-data"
      is:inline
      set:html={JSON.stringify(i18nData)}
    />
    <slot />
    <script>
      import '../scripts/client';
    </script>
  </body>
</html>
