# Resend transactional email, used by src/pages/api/contact.ts (a Vercel Serverless Function).
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact-form submissions.
# The sender's address is set as Reply-To, so you can reply straight from Gmail.
CONTACT_EMAIL=hello@ronaldterceros.com

# Cloudflare Turnstile (optional anti-spam). Leave both unset to disable: the
# form works without it. Create a widget in the Cloudflare dashboard (Turnstile).
# PUBLIC_ prefix = exposed to the browser (the Turnstile site key is public).
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
