# Resend transactional email, used by src/pages/api/contact.ts (a Vercel Serverless Function).
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact-form submissions.
# The sender's address is set as Reply-To, so you can reply straight from Gmail.
CONTACT_EMAIL=hello@ronaldterceros.com
